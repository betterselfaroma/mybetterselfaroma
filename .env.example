# Supabase — membership / referral / points system
# Create a free project at https://supabase.com, then Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Project Settings → API). SERVER ONLY — never expose.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails allowed into /admin (e.g. betterselfaroma@gmail.com)
ADMIN_EMAILS=

# Public site URL, used to build referral links (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://scentknowsyou.com
